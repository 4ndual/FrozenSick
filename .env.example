# GitHub OAuth App credentials (create at https://github.com/settings/developers)
# Callback URL: https://YOUR_DOMAIN/api/auth/callback
# These are server-side only (used in API routes)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public env vars (available client-side) - must be prefixed with PUBLIC_
# These are used by the timeline app for GitHub sync
PUBLIC_GITHUB_OWNER=4ndual
PUBLIC_GITHUB_REPO=FrozenSick
PUBLIC_GITHUB_BRANCH=main
